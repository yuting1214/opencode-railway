# ── Provider keys ───────────────────────────────────────────
# Set at least one. OpenCode reads these automatically when you run it.
# Alternatively, leave them blank and run `opencode auth login` after you
# SSH in — credentials are stored on the /workspace volume and persist.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ── Optional: GitHub ────────────────────────────────────────
# A token here authenticates `gh` and HTTPS `git` inside the box on boot.
GITHUB_TOKEN=

# ── Optional: git identity for commits made from the box ────
GIT_USER_NAME=
GIT_USER_EMAIL=
