# ── Provider keys ───────────────────────────────────────────
# Set at least one. OpenCode reads these automatically when you run it.
# Alternatively, leave them blank and run `opencode auth login` after you
# SSH in — credentials are stored on the /workspace volume and persist.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ── Optional: GitHub ────────────────────────────────────────
# A token here authenticates `gh` and HTTPS `git` inside the box on boot.
GITHUB_TOKEN=

# ── Optional: git identity for commits made from the box ────
GIT_USER_NAME=
GIT_USER_EMAIL=

# ── Web UI (opencode web) ───────────────────────────────────
# The container's main process is `opencode web`, served on the public Railway
# domain and protected with HTTP basic auth. Leave the password blank to have
# one generated on first boot and persisted on the volume (printed in the deploy
# logs). Set it explicitly to choose your own.
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=
# Port the web UI binds to (Railway maps the public domain to this). Default 8080.
PORT=8080
